# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sms

# JWT
JWT_ACCESS_SECRET=your-64-char-random-string-change-me
JWT_REFRESH_SECRET=your-64-char-random-string-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# SMTP (for forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
